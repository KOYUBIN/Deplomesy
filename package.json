{
  "name": "deplomesy",
  "version": "1.0.0",
  "description": "StarCraft Diplomacy Multiplayer Browser Game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server:dev": "npm run dev --prefix server",
    "server:build": "npm install --prefix server && npm run build --prefix server",
    "server:start": "npm run start --prefix server",
    "dev:all": "concurrently -n VITE,SERVER -c cyan,yellow \"npm run dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.2.0",
    "vite": "^5.0.0"
  }
}
